---
import type { Project } from '../data/site';
const { project, index = 0 } = Astro.props as { project: Project; index?: number };
---
<article class="project-card" data-project-card data-categories={project.category.join('|').toLowerCase()} data-reveal>
  <a class:list={['project-cover', { 'project-cover--empty': !project.cover }]} href={`/work/${project.slug}/`} aria-label={`Read the ${project.name} case study`}>
    {project.cover ? <img src={project.cover} alt={project.coverAlt} loading={index > 1 ? 'lazy' : 'eager'} /> : <span aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>}
    <div class="project-cover-meta"><small>{project.type}</small><strong>{project.status}</strong></div>
  </a>
  <div class="project-card-copy">
    <p class="eyebrow">{project.category.slice(0, 2).join(' · ')}</p>
    <h2><a href={`/work/${project.slug}/`}>{project.name}</a></h2>
    <p>{project.shortDescription}</p>
    <div class="tag-list">{project.technologies.slice(0, 4).map((technology) => <span>{technology}</span>)}</div>
    <div class="card-actions">
      <a class="text-link" href={`/work/${project.slug}/`}>View case study <i class="ph ph-arrow-right" aria-hidden="true"></i></a>
      {project.repository && <a class="icon-link" href={project.repository} target="_blank" rel="noreferrer" aria-label={`View ${project.name} source on GitHub`}><i class="ph ph-github-logo" aria-hidden="true"></i></a>}
      {!project.repository && <span class="repo-status"><i class="ph ph-lock-key" aria-hidden="true"></i> Private source</span>}
    </div>
  </div>
</article>
