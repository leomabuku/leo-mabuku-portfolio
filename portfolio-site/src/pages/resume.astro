---
import BaseLayout from '../layouts/BaseLayout.astro';
import AvailabilityBanner from '../components/AvailabilityBanner.astro';
import { profile, education, experience, skillGroups, featuredProjects } from '../data/site';
---
<BaseLayout title="Resume | Leo Mabuku" description="Resume of Leo Mabuku: fourth-year Computer Science student, software developer and entrepreneur in Kitwe, Zambia.">
  <section class="page-hero resume-hero" data-reveal><p class="eyebrow">Resume</p><h1>Skills backed by<br/><em>projects and operations.</em></h1><p>Fourth-year Computer Science student with practical work across Android, web, systems, interpreter development, business operations and networking.</p><div class="actions"><button class="button print-resume" type="button"><i class="ph ph-printer" aria-hidden="true"></i> Print or save as PDF</button><a class="text-link" href={`mailto:${profile.email}`}>Request a copy <i class="ph ph-arrow-right" aria-hidden="true"></i></a></div></section>
  <div class="resume-document section-shell">
    <section class="resume-summary" data-reveal><p class="eyebrow">Professional summary</p><h2>Software developer with a practical, systems-oriented approach.</h2><p>Fourth-year Bachelor of Science in Computer Science student with project experience in Android, web, systems and programming-language development. Combines problem analysis with entrepreneurship, technical support and real-world product development.</p></section>
    <section class="resume-section" data-reveal><p class="eyebrow">Technical skills</p><div class="skill-groups">{skillGroups.map((group) => <div><h3>{group.title}</h3><div class="tag-list">{group.items.map((item) => <span>{item}</span>)}</div></div>)}</div></section>
    <section class="resume-section" data-reveal><p class="eyebrow">Experience</p><div class="timeline">{experience.map((item) => <article><div class="timeline-meta"><span>{item.period}</span><small>{item.location}</small></div><div><h3>{item.title}</h3><h4>{item.organisation}</h4><p>{item.summary}</p><ul>{item.bullets.map((bullet) => <li>{bullet}</li>)}</ul></div></article>)}</div></section>
    <section class="resume-section" data-reveal><p class="eyebrow">Education</p><div class="timeline">{education.map((item) => <article><div class="timeline-meta"><span>{item.period}</span><small>{item.location}</small></div><div><h3>{item.qualification}</h3><h4>{item.institution}</h4><p>{item.detail}</p></div></article>)}</div></section>
    <section class="resume-section" data-reveal><p class="eyebrow">Selected project evidence</p><div class="resume-projects">{featuredProjects.map((project) => <a href={`/work/${project.slug}/`}><span><strong>{project.name}</strong><small>{project.role} · {project.status}</small></span><i class="ph ph-arrow-up-right" aria-hidden="true"></i></a>)}</div></section>
  </div>
  <AvailabilityBanner />
  <script>document.querySelector('.print-resume')?.addEventListener('click', () => window.print());</script>
</BaseLayout>
