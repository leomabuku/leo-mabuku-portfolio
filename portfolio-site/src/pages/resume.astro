---
import BaseLayout from '../layouts/BaseLayout.astro'; import profile from '../data/profile.json'; import projects from '../data/projects.json';
---
<BaseLayout title="Resume — Leo Mabuku"><section class="page-hero" data-reveal><p class="eyebrow">Resume</p><h1>Skills backed by<br/><em>work you can inspect.</em></h1><p>This page currently presents verified skills and public project evidence. Qualifications, certifications and a downloadable PDF will appear once the approved Drive source is connected.</p></section><section class="resume-grid"><div data-reveal><p class="eyebrow">Capabilities</p><div class="skill-list">{profile.skills.map(skill=><span>{skill}</span>)}</div></div><div data-reveal><p class="eyebrow">Project evidence</p>{projects.map(p=><a class="evidence" href={`https://github.com/leomabuku/${p.repo}`} target="_blank"><span><strong>{p.name}</strong><small>{p.type}</small></span><i class="ph ph-arrow-up-right"></i></a>)}</div></section><section class="status-note"><i class="ph ph-info"></i><p><strong>Resume PDF not published yet.</strong><br/>The download will be enabled only after Leo supplies and approves the document.</p></section></BaseLayout>
