---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import AvailabilityBanner from '../components/AvailabilityBanner.astro';
import { profile, featuredProjects } from '../data/site';
const services = [
  ['ph-code', 'Software development', 'I translate requirements into clear, maintainable applications and systems.'],
  ['ph-browser', 'Web development', 'I build responsive, content-driven web experiences with practical deployment in mind.'],
  ['ph-device-mobile', 'Android development', 'I develop Kotlin-based mobile applications around real user and business workflows.'],
  ['ph-flow-arrow', 'Systems thinking', 'I break complex problems into connected parts, rules, data and dependable interfaces.'],
];
---
<BaseLayout>
  <section class="hero">
    <div class="hero-copy" data-reveal>
      <p class="location"><i class="ph ph-map-pin" aria-hidden="true"></i>{profile.location}</p>
      <h1>Leo<br/><em>Mabuku</em></h1>
      <p class="role">Software Developer <span>·</span> Student <span>·</span> Entrepreneur</p>
      <div class="rule"></div>
      <p class="intro">{profile.intro}</p>
      <div class="actions"><a class="button" href="#featured">View my work <i class="ph ph-arrow-right" aria-hidden="true"></i></a><a class="text-link" href="/contact/">Contact Leo <i class="ph ph-arrow-right" aria-hidden="true"></i></a></div>
    </div>
    <div class="hero-image"><img src={profile.avatar} alt="Leo Mabuku wearing a dark suit in a black-and-white portrait" fetchpriority="high" /></div>
  </section>

  <section class="credibility-strip" aria-label="Professional summary">
    <span>Fourth-year Computer Science student</span><span>Based in Kitwe, Zambia</span><span>Web · Android · Systems</span><span>Open to opportunities</span>
  </section>

  <section class="section-shell services-section">
    <div class="section-heading" data-reveal><p class="eyebrow">What I do</p><h2>From analysis to<br/><em>working software.</em></h2><p>My strongest work connects technical decisions to useful outcomes.</p></div>
    <div class="services-grid">{services.map(([icon, title, text]) => <article data-reveal><i class={`ph ${icon}`} aria-hidden="true"></i><h3>{title}</h3><p>{text}</p></article>)}</div>
  </section>

  <section class="section-shell featured-section" id="featured">
    <div class="section-heading section-heading--row" data-reveal><div><p class="eyebrow">Featured work</p><h2>Evidence across<br/><em>different systems.</em></h2></div><a class="text-link" href="/work/">Explore all projects <i class="ph ph-arrow-right" aria-hidden="true"></i></a></div>
    <div class="project-grid">{featuredProjects.map((project, index) => <ProjectCard project={project} index={index} />)}</div>
  </section>

  <section class="business-proof" data-reveal>
    <div><p class="eyebrow">Built through code and business</p><h2>Technical decisions grounded in <em>real operations.</em></h2></div>
    <div><p>Before and during university, I have managed retail operations, handled procurement and customer relationships, repaired computers and launched a Starlink-powered internet service. Those experiences influence how I build software: around actual users, constraints and workflows.</p><dl><div><dt>29</dt><dd>active internet-service subscribers</dd></div><div><dt>2022</dt><dd>Leo M. Suppliers formally registered</dd></div><div><dt>3</dt><dd>connected disciplines: software, business and networking</dd></div></dl></div>
  </section>

  <AvailabilityBanner />
</BaseLayout>
