---
import BaseLayout from '../layouts/BaseLayout.astro'; import ProjectRow from '../components/ProjectRow.astro'; import projects from '../data/projects.json'; import profile from '../data/profile.json';
---
<BaseLayout title="Leo Mabuku — Entrepreneur & Software Developer">
  <section class="hero">
    <div class="hero-copy" data-reveal><p class="location"><i class="ph ph-map-pin"></i>{profile.location}</p><h1>Leo<br/><em>Mabuku</em></h1><p class="role">Entrepreneur <span>&</span> Software Developer</p><div class="rule"></div><p class="intro">{profile.intro}</p><div class="actions"><a class="button" href="#work">View selected work <i class="ph ph-arrow-right"></i></a><a class="text-link" href="/contact/">Contact Leo <i class="ph ph-arrow-right"></i></a></div></div>
    <div class="hero-image" aria-hidden="true"><img src={profile.avatar} alt="" /></div>
  </section>
  <section class="projects-section" id="work">
    <div class="section-intro" data-reveal><p class="eyebrow">Selected systems</p><h2>Systems built to solve <em>real problems.</em></h2><p>Problem first. Purpose built. Evidence in the open.</p><a class="text-link" href="/work/">Explore all work <i class="ph ph-arrow-right"></i></a></div>
    <div class="project-list">{projects.map((p,i) => <ProjectRow project={p} index={i} />)}</div>
  </section>
  <section class="mindset" data-reveal><div><p class="eyebrow">Mindset</p><h2>Entrepreneurial by nature.<br/>Builder by choice.</h2></div><div class="principles"><article><i class="ph ph-lightbulb"></i><h3>Solve real problems</h3><p>I start with people and problems, not technology.</p></article><article><i class="ph ph-code"></i><h3>Build with discipline</h3><p>Clear code, simple systems and thoughtful design.</p></article><article><i class="ph ph-rocket-launch"></i><h3>Ship, learn, improve</h3><p>I value practical progress and continuous learning.</p></article><article><i class="ph ph-trend-up"></i><h3>Create value</h3><p>I connect technical choices to useful outcomes.</p></article></div></section>
</BaseLayout>
